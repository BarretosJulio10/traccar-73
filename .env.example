# Supabase — copie este arquivo para .env e preencha com seus valores reais
# NUNCA commite o arquivo .env no git

VITE_SUPABASE_PROJECT_ID="seu-project-id-aqui"
VITE_SUPABASE_PUBLISHABLE_KEY="sua-anon-key-aqui"
VITE_SUPABASE_URL="https://seu-project-id.supabase.co"

# Web Push VAPID Keys (sistema legado — mantido durante migração)
# Gere com: npx web-push generate-vapid-keys
# Coloque a chave PRIVADA como segredo no Supabase (VAPID_PRIVATE_KEY)
VITE_VAPID_PUBLIC_KEY="sua-vapid-public-key-aqui"

# OneSignal — Sistema primário de push (substitui VAPID)
# 1. Crie conta em app.onesignal.com → New App → Web Push
# 2. App ID: Settings → Keys & IDs → OneSignal App ID
# 3. REST API Key: Settings → Keys & IDs → REST API Key
# 4. Configure no Supabase Edge Functions:
#    supabase secrets set ONESIGNAL_APP_ID=xxx ONESIGNAL_REST_API_KEY=os_v2_xxx
VITE_ONESIGNAL_APP_ID="seu-onesignal-app-id-aqui"
